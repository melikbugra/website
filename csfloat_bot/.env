# CSFloat Trading Bot — Environment Variables
# Copy this file to .env and fill in your real credentials.
# DO NOT commit .env to version control.

# ── Cookies (ZORUNLU) ─────────────────────────────────────────────────────────
#
# Chrome'da csfloat.com'a giriş yap.
# F12 → Network → filter: "listings" → herhangi bir isteğe tıkla
# Request Headers → "Cookie" satırını tüm içeriğiyle kopyala.
#
# Örnek:  session=abc123; cf_clearance=xyz789; __cf_bm=abc...
#
CSFLOAT_COOKIES=_gcl_au=1.1.261203450.1779289142; _gid=GA1.2.1095353714.1779289142; __stripe_mid=49bc3955-c0ea-4730-9f3b-5f6841322cb15c7204; session=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdGVhbV9pZCI6Ijc2NTYxMTk4MTg1NjY3MzQ3Iiwibm9uY2UiOjAsImltcGVyc29uYXRlZCI6ZmFsc2UsImlzcyI6ImNzdGVjaCIsImV4cCI6MTc3OTcyMTIxNX0.5hnGjqsRlxysu4DdgB2g_XS-ozeo30ut6JK4bR8Pcig; _ga=GA1.1.1649478551.1779289142; _ga_3V4JQEGNYC=GS2.1.s1779307366$o5$g1$t1779307680$j51$l0$h0


# ── Bearer Token (OPSİYONEL) ─────────────────────────────────────────────────
#
# CSFloat tarayıcı oturumu Authorization header göndermez; cookie yeterlidir.
# Aynı Network isteğinde Authorization header GÖRÜYORSAN kopyala (eyJ... kısmı).
# Geliştirici API key'in varsa onu da buraya yazabilirsin.
# Görmüyorsan bu satırı boş bırak veya tamamen sil.
#
CSFLOAT_BEARER_TOKEN=cQtCvrb8mQFMO5Xm3WTB90ZoHvgVeNqY


# Telegram notifications (optional)
# 1. Create a bot: talk to @BotFather on Telegram → /newbot → copy token
# 2. Get your chat_id: talk to @userinfobot → it replies with your numeric ID
TELEGRAM_BOT_TOKEN=8993555388:AAHf408wnL8DnT4TPiqR_-VFhKnAuwX0q28
TELEGRAM_CHAT_ID=8503988954