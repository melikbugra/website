# CSFloat Trading Bot — Environment Variables
# Copy this file to .env and fill in your real credentials.
# DO NOT commit .env to version control.

# ── Cookies (ZORUNLU) ─────────────────────────────────────────────────────────
#
# Chrome'da csfloat.com'a giriş yap.
# F12 → Network → filter: "listings" → herhangi bir isteğe tıkla
# Request Headers → "Cookie" satırını tüm içeriğiyle kopyala.
#
# Örnek:  session=abc123; cf_clearance=xyz789; __cf_bm=abc...
#
CSFLOAT_COOKIES=_gcl_au=1.1.261203450.1779289142; __stripe_mid=49bc3955-c0ea-4730-9f3b-5f6841322cb15c7204; session=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdGVhbV9pZCI6Ijc2NTYxMTk4MTg1NjY3MzQ3Iiwibm9uY2UiOjAsImltcGVyc29uYXRlZCI6ZmFsc2UsImlzcyI6ImNzdGVjaCIsImV4cCI6MTc4MjQ5OTU5MH0.rFy4ZCLUFfVmc_BbxHekMhWATa2bdUxs2mwFP3QpTNg; _gid=GA1.2.468463188.1782147402; _ga=GA1.1.1649478551.1779289142; __stripe_sid=6fc7c355-060f-43c3-b23a-ff06c0a3de8fd490ce; _ga_3V4JQEGNYC=GS2.1.s1782200233$o76$g1$t1782200714$j60$l0$h0

# ── Bearer Token (OPSİYONEL) ─────────────────────────────────────────────────
#
# CSFloat tarayıcı oturumu Authorization header göndermez; cookie yeterlidir.
# Aynı Network isteğinde Authorization header GÖRÜYORSAN kopyala (eyJ... kısmı).
# Geliştirici API key'in varsa onu da buraya yazabilirsin.
# Görmüyorsan bu satırı boş bırak veya tamamen sil.
#
CSFLOAT_BEARER_TOKEN=cQtCvrb8mQFMO5Xm3WTB90ZoHvgVeNqY


